# ── Database ──────────────────────────────────────────────
POSTGRES_USER=soukpilot
POSTGRES_PASSWORD=soukpilot_secret
POSTGRES_DB=soukpilot_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://soukpilot:soukpilot_secret@postgres:5432/soukpilot_db

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── OpenAI ────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_STT_MODEL=whisper-1
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy

# ── App ───────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-in-production
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── JWT Auth (single admin user — demo) ──────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=soukpilot2024
JWT_EXPIRE_HOURS=8

# ── Vector Store ──────────────────────────────────────────
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# ── File uploads ──────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=20

# ── Twilio WhatsApp webhook (optional) ────────────────────
# Leave blank to skip signature validation in dev/demo mode.
# In production: fill these in and point Twilio's sandbox webhook to:
#   POST https://<your-domain>/api/webhooks/whatsapp
# ngrok for live demo:  ngrok http 8000  →  use the https URL in Twilio sandbox settings
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
